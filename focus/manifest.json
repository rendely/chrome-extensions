{
  "manifest_version": 3,
  "name": "Focus",
  "version": "1.0",
  "description": "Minimal new tab to-do list with tab mentions and site blocking",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage", "tabs", "declarativeNetRequest"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  }
}
