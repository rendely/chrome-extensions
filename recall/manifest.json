{
  "manifest_version": 3,
  "name": "Recall MVP",
  "description": "Capture readable page text, store in IndexedDB, and search with FlexSearch.",
  "version": "0.1.0",
  "permissions": [],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Recall"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
